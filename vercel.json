{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/dashboard",
      "destination": "/calibration/dashboard/populace",
      "permanent": false
    },
    {
      "source": "/calibration/dashboard",
      "destination": "/calibration/dashboard/populace",
      "permanent": false
    },
    {
      "source": "/papers/l0",
      "destination": "/sparsity/paper",
      "permanent": true
    },
    {
      "source": "/papers/dynamics",
      "destination": "/dynamics/paper",
      "permanent": true
    },
    {
      "source": "/papers/:slug",
      "destination": "/:slug/paper",
      "permanent": true
    },
    {
      "source": "/imputation",
      "destination": "/support",
      "permanent": true
    },
    {
      "source": "/imputation/paper",
      "destination": "/support/paper",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/calibration/dashboard/:path*",
      "destination": "https://calibration-diagnostics.vercel.app/calibration/dashboard/:path*"
    }
  ]
}